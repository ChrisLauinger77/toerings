{
  "$schema": "https://schema.tauri.app/config/2",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "bundle": {
    "active": true,
    "category": "DeveloperTool",
    "copyright": "",
    "targets": "all",
    "externalBin": [],
    "icon": [
      "icons/logo-256x256.png",
      "icons/logo-400x400.png"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    },
    "longDescription": "A lightweight desktop system monitor inspired by Conky SeaMod.",
    "macOS": {
      "entitlements": null,
      "exceptionDomain": "",
      "frameworks": [],
      "providerShortName": null,
      "signingIdentity": "-"
    },
    "resources": [],
    "shortDescription": "A lightweight desktop system monitor.",
    "linux": {
      "deb": {
        "depends": []
      }
    }
  },
  "productName": "ToeRings",
  "mainBinaryName": "ToeRings",
  "version": "0.1.0",
  "identifier": "io.toerings",
  "plugins": {},
  "app": {
    "withGlobalTauri": false,
    "macOSPrivateApi": true,
    "security": {
      "csp": null
    },
    "windows": [
      {
        "fullscreen": false,
        "height": 850,
        "width": 325,
        "x": 30,
        "y": 50,
        "resizable": true,
        "title": "toerings",
        "decorations": false,
        "transparent": true,
        "useHttpsScheme": true
      }
    ]
  }
}
